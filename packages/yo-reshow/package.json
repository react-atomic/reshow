{
  "version": "0.19.2",
  "name": "yo-reshow",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-atomic/reshow",
    "directory": "packages/yo-reshow"
  },
  "homepage": "https://github.com/react-atomic/reshow/tree/main/packages/yo-reshow",
  "description": "Yo utility for reshow",
  "keywords": [
    "yo",
    "Yeoman"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "ISC",
  "dependencies": {
    "call-func": "^0.5.3",
    "mem-fs": "^4.1.4",
    "mkdirp": "3.0.1",
    "object-nested": "^0.2.0",
    "parse-ini-string": "^0.2.0",
    "reshow-constant": "^0.18.0",
    "yeoman-generator": "^5.4.2",
    "yosay": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2",
    "yo-unit": "^0.17.7"
  },
  "exports": {
    "types": "./dist/types/index.d.ts",
    "require": "./dist/index.js",
    "import": "./dist/index.js"
  },
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "build:clean": "find ./dist -name '*.*' | xargs rm -rf",
    "build:src": "bun build src/index.ts --outdir dist --target node --external parse-ini-string",
    "build:types": "bun tsc -p ./",
    "build": "npm run build:clean && npm run build:src && npm run build:types",
    "test": "npm run build && bun test --timeout 5000 ./src/__tests__/",
    "prepublishOnly": "npm t"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
