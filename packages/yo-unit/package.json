{
  "version": "0.19.0",
  "name": "yo-unit",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-atomic/reshow",
    "directory": "packages/yo-unit"
  },
  "homepage": "https://github.com/react-atomic/reshow/tree/main/packages/yo-unit",
  "description": "Yeoman test utility.",
  "keywords": [],
  "author": "Hill <hill@kimo.com>",
  "license": "ISC",
  "dependencies": {
    "mem-fs": "^4.1.3",
    "reshow-constant": "^0.18.0",
    "reshow-unit-dom": "^0.7.5",
    "yeoman-assert": "^3.1.1",
    "yeoman-environment": "^3.x",
    "yeoman-test": "^6.x"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "exports": {
    "types": "./dist/types/index.d.ts",
    "require": "./dist/index.js",
    "import": "./dist/index.js"
  },
  "types": "./dist/types/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "build:clean": "find ./dist -name '*.*' | xargs rm -rf",
    "build:src": "bun build src/index.ts --outdir dist --target node --external parse-ini-string --external yeoman-generator",
    "build:types": "bun tsc -p ./",
    "build": "npm run build:clean && npm run build:src && npm run build:types",
    "test": "npm run build && bun test --timeout 5000 ./src/__tests__/",
    "prepublishOnly": "npm t"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=14"
  }
}
